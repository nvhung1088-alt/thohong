{
  "version": 2,
  "builds": [
    { "src": "server.js", "use": "@vercel/node" },
    { "src": "public/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "server.js" },
    { "src": "/danh-muc/(.*)", "dest": "server.js" },
    { "src": "/san-pham/(.*)", "dest": "server.js" },
    { "src": "/(.*)", "dest": "public/$1" }
  ],
  "crons": [
    {
      "path": "/api/pos/sync",
      "schedule": "0 0 * * *"
    }
  ]
}
